# In .env.local kopieren und anpassen
DATABASE_URL=postgres://festival:festival@localhost:5432/festival
# Gehostete DBs (Neon, Supabase, ...): ?sslmode=require einfach dranlassen –
# die App übersetzt das selbst in eine explizite TLS-Config (keine pg-Warnung).
#   DATABASE_URL=postgres://...?sslmode=require
#   DATABASE_SSL=no-verify   # nur falls das Zertifikat nicht verifizierbar ist
# Öffentliche Basis-URL für SEO (Canonical/OpenGraph/Sitemap/robots.txt).
# In Produktion auf die echte Domain setzen, sonst greift localhost.
# Achtung: wird beim `next build` eingebacken – muss also zur Build-Zeit
# gesetzt sein (in .env.local reicht, die lädt Next auch beim Build).
#   APP_URL=https://buddy.example.com
# Admin-Passwort: langes, zufälliges wählen. Ohne diese Variable ist der
# Admin-Bereich in der Produktion deaktiviert (fail closed); lokal greift
# ersatzweise "wacken2026".
ADMIN_PASSWORD=bitte-langes-zufaelliges-passwort-setzen
