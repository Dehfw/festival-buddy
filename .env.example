# Gehostete DBs (Neon, Supabase, ...): ?sslmode=require einfach dranlassen –
# die App übersetzt das selbst in eine explizite TLS-Config (keine pg-Warnung).
#   DATABASE_URL=postgres://...?sslmode=require
#   DATABASE_SSL=no-verify   # nur falls das Zertifikat nicht verifizierbar ist
