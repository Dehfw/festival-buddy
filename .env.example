# In .env.local kopieren und anpassen
DATABASE_URL=postgres://festival:festival@localhost:5432/festival
# Gehostete DBs (Neon, Supabase, ...): ?sslmode=require einfach dranlassen –
# die App übersetzt das selbst in eine explizite TLS-Config (keine pg-Warnung).
#   DATABASE_URL=postgres://...?sslmode=require
#   DATABASE_SSL=no-verify   # nur falls das Zertifikat nicht verifizierbar ist
# Admin-Passwort: langes, zufälliges wählen. Ohne diese Variable ist der
# Admin-Bereich in der Produktion deaktiviert (fail closed); lokal greift
# ersatzweise "wacken2026".
ADMIN_PASSWORD=bitte-langes-zufaelliges-passwort-setzen

# HMAC-Schlüssel für Session-/Challenge-Cookies. Ohne die Variable wird er
# aus der DATABASE_URL abgeleitet – setzen ist empfohlen.
#   AUTH_SECRET=langer-zufaelliger-string

# Passkey / WebAuthn -----------------------------------------------------------
# Relying-Party-ID = die Domain, an die Passkeys gebunden werden.
# Default: Hostname des Requests. WICHTIG die nackte Domain OHNE "www."
# eintragen – so gelten die Passkeys für www.festivalbuddy.app UND
# festivalbuddy.app. Mit "www." wären sie nur auf der www-Variante gültig.
#   WEBAUTHN_RP_ID=festivalbuddy.app
# Erwartete Origin. Default: Origin des Requests – am besten NICHT setzen,
# dann funktionieren www- und apex-Domain gleichermaßen. Fest verdrahtet
# akzeptiert der Server nur genau diese eine Origin.
#   WEBAUTHN_ORIGIN=https://festivalbuddy.app
